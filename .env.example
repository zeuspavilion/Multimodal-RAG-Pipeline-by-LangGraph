# ================================================
# Zeus — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git.
# ================================================

# ─── AI API Keys ───────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
HF_TOKEN=your_huggingface_token_here

# ─── LangSmith (optional, for tracing) ─────────
LANGCHAIN_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ─── Database ───────────────────────────────────
# Neon (cloud): postgresql://user:pass@host/dbname?sslmode=require
# Local Docker:  postgresql://postgres:postgres@localhost:5432/zeus
NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Redis (optional) ────────────────────────────
# Leave blank to disable caching (app will still work)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Auth ────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET_KEY=change_me_to_a_secure_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── Deployment ──────────────────────────────────
# "development" enables HF mirror + SSL bypass for restricted networks
# "production"  skips the mirror (model pre-downloaded in Docker image)
ENVIRONMENT=development

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Azure Blob Storage (optional, falls back to local disk if blank) ───
# Get from: Azure Portal → Storage Account → Access keys → Connection string
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=zeus-uploads

